<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ══════════════════════════════════════════════
         GameLauncherPro · 深色轻奢暖金风
         Dark Luxury Warm Gold Theme
         ══════════════════════════════════════════════ -->

    <!-- ─── 暗色主题色彩 ─── -->
    <Color x:Key="DarkAccent">#D4A574</Color>
    <Color x:Key="DarkAccent2">#8B5A2B</Color>
    <Color x:Key="DarkAccentGlow">#26D4A574</Color>
    <Color x:Key="DarkMainBg">#17120F</Color>
    <Color x:Key="DarkPanelBg">#1E1814</Color>
    <Color x:Key="DarkCardBg">#2B1F1A</Color>
    <Color x:Key="DarkGlassBg">#1A2B1F1A</Color>
    <Color x:Key="DarkBorder">#3A2E28</Color>
    <Color x:Key="DarkBorderLight">#4A3D35</Color>
    <Color x:Key="DarkTextPrimary">#F5E8D7</Color>
    <Color x:Key="DarkTextSecondary">#A89078</Color>
    <Color x:Key="DarkTextMuted">#6B5A4E</Color>
    <Color x:Key="DarkHover">#352820</Color>
    <Color x:Key="DarkPlaceholder">#1A1510</Color>

    <!-- ─── 动态主题键 ─── -->
    <SolidColorBrush x:Key="ThemeToggleBg" Color="Transparent"/>

    <Color x:Key="AccentColor">#D4A574</Color>
    <Color x:Key="Accent2Color">#8B5A2B</Color>
    <Color x:Key="AccentGlowColor">#26D4A574</Color>
    <Color x:Key="MainBgColor">#17120F</Color>
    <Color x:Key="PanelBgColor">#1E1814</Color>
    <Color x:Key="CardBgColor">#2B1F1A</Color>
    <Color x:Key="GlassBgColor">#1A2B1F1A</Color>
    <Color x:Key="BorderColor">#3A2E28</Color>
    <Color x:Key="BorderLightColor">#4A3D35</Color>
    <Color x:Key="TextPrimaryColor">#F5E8D7</Color>
    <Color x:Key="TextSecondaryColor">#A89078</Color>
    <Color x:Key="TextMutedColor">#6B5A4E</Color>
    <Color x:Key="HoverColor">#352820</Color>
    <Color x:Key="PlaceholderColor">#1A1510</Color>
    <Color x:Key="ChartBgColor">#2B1F1A</Color>
    <Color x:Key="GoldColor">#D4A574</Color>
    <Color x:Key="ShadowColor">#000000</Color>
    <Color x:Key="ShadowGlowColor">#40D4A574</Color>

    <!-- ─── 动态 Brush ─── -->
    <SolidColorBrush x:Key="AccentBrush" Color="#D4A574"/>
    <SolidColorBrush x:Key="Accent2Brush" Color="#8B5A2B"/>
    <SolidColorBrush x:Key="MainBgBrush" Color="#17120F"/>
    <SolidColorBrush x:Key="PanelBgBrush" Color="#1E1814"/>
    <SolidColorBrush x:Key="CardBgBrush" Color="#2B1F1A"/>
    <SolidColorBrush x:Key="GlassBgBrush" Color="#1A2B1F1A"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#3A2E28"/>
    <SolidColorBrush x:Key="BorderLightBrush" Color="#4A3D35"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F5E8D7"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#A89078"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="#6B5A4E"/>
    <SolidColorBrush x:Key="HoverBrush" Color="#352820"/>
    <SolidColorBrush x:Key="PlaceholderBrush" Color="#1A1510"/>
    <SolidColorBrush x:Key="ChartBgBrush" Color="#2B1F1A"/>
    <SolidColorBrush x:Key="GoldBrush" Color="#D4A574"/>
    <SolidColorBrush x:Key="ChartAxisBrush" Color="#A89078"/>
    <SolidColorBrush x:Key="ChartLabelBrush" Color="#F5E8D7"/>

    <!-- Accent 渐变刷 -->
    <LinearGradientBrush x:Key="AccentGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{DynamicResource AccentColor}" Offset="0"/>
        <GradientStop Color="{DynamicResource Accent2Color}" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="AccentGradientBrushHover" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{DynamicResource Accent2Color}" Offset="0.15"/>
        <GradientStop Color="{DynamicResource AccentColor}" Offset="1"/>
    </LinearGradientBrush>

    <!-- ─── 字体 ─── -->
    <FontFamily x:Key="AppFont">Segoe UI, Microsoft YaHei</FontFamily>

    <Style TargetType="Window">
        <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
        <Setter Property="TextElement.Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
    </Style>

    <!-- ══════════════════════════════════════════════
         控件样式
         ══════════════════════════════════════════════ -->

    <!-- GoldButton -->
    <Style TargetType="Button" x:Key="GoldButton">
        <Setter Property="Background" Value="{StaticResource GlassBgBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Padding" Value="14,7"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6" Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <Border.Effect>
                            <DropShadowEffect Color="{DynamicResource ShadowColor}"
                                              BlurRadius="4" ShadowDepth="1" Opacity="0.3"/>
                        </Border.Effect>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            <Setter TargetName="border" Property="Background" Value="{StaticResource HoverBrush}"/>
                            <Setter TargetName="border" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="{DynamicResource AccentGlowColor}"
                                                      BlurRadius="8" ShadowDepth="1" Opacity="0.6"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource HoverBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- AccentButton -->
    <Style TargetType="Button" x:Key="AccentButton">
        <Setter Property="Foreground" Value="#17120F"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Padding" Value="14,7"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{StaticResource AccentGradientBrush}"
                            CornerRadius="6" Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <Border.Effect>
                            <DropShadowEffect Color="{DynamicResource AccentGlowColor}"
                                              BlurRadius="10" ShadowDepth="1" Opacity="0.5"/>
                        </Border.Effect>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource AccentGradientBrushHover}"/>
                            <Setter TargetName="border" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="{DynamicResource AccentGlowColor}"
                                                      BlurRadius="16" ShadowDepth="1" Opacity="0.7"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ══════════════════════════════════════════════
         卡片样式
         ══════════════════════════════════════════════ -->

    <!-- GameCard · 大区块卡片 + 底部暖金微光 -->
    <Style TargetType="Border" x:Key="GameCard">
        <Setter Property="Background" Value="{StaticResource CardBgBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="10"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#25D4A574"
                                  BlurRadius="6" ShadowDepth="1" Opacity="0.6"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- GameCardHover · 游戏个体卡片 + hover 暖金辉光 -->
    <Style TargetType="Border" x:Key="GameCardHover">
        <Setter Property="Background" Value="{StaticResource CardBgBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="10"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="{DynamicResource ShadowColor}"
                                  BlurRadius="10" ShadowDepth="2" Opacity="0.4"/>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                <Setter Property="Background" Value="{StaticResource HoverBrush}"/>
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect Color="{DynamicResource ShadowGlowColor}"
                                          BlurRadius="24" ShadowDepth="3" Opacity="0.75"/>
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- HeaderPanel -->
    <Style TargetType="Border" x:Key="HeaderPanel">
        <Setter Property="Background" Value="{StaticResource PanelBgBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="Padding" Value="20,14"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="{DynamicResource ShadowGlowColor}"
                                  BlurRadius="12" ShadowDepth="0" Opacity="0.35"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ScrollViewer -->
    <Style TargetType="ScrollViewer">
        <Setter Property="Background" Value="Transparent"/>
    </Style>

    <!-- TextBox -->
    <Style TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource PlaceholderBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="8,6"/>
        <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}"/>
        <Setter Property="FontSize" Value="13"/>
        <Style.Triggers>
            <Trigger Property="IsKeyboardFocused" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ComboBox -->
    <Style TargetType="ComboBox">
        <Setter Property="Background" Value="{StaticResource PlaceholderBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <ToggleButton x:Name="ToggleButton"
                                      Background="{TemplateBinding Background}"
                                      BorderBrush="{TemplateBinding BorderBrush}"
                                      BorderThickness="{TemplateBinding BorderThickness}"
                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                      Focusable="False" ClickMode="Press">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Grid>
                                        <Border x:Name="bd"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="6" Padding="10,5"/>
                                        <Path x:Name="Arrow" Data="M0,0L4,4L8,0"
                                              Stroke="{StaticResource TextSecondaryBrush}"
                                              StrokeThickness="1.5"
                                              HorizontalAlignment="Right" Margin="0,0,10,0"
                                              VerticalAlignment="Center"
                                              Fill="{StaticResource TextSecondaryBrush}"/>
                                    </Grid>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>
                        <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                          ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                          Margin="10,5,30,5" VerticalAlignment="Center"
                                          HorizontalAlignment="Left"/>
                        <Popup x:Name="Popup" Placement="Bottom"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               AllowsTransparency="True" Focusable="False"
                               PopupAnimation="Slide">
                            <Grid MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                  MinWidth="{TemplateBinding ActualWidth}"
                                  x:Name="DropDown" SnapsToDevicePixels="True">
                                <Border x:Name="DropDownBorder"
                                        Background="{StaticResource PlaceholderBrush}"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1" CornerRadius="6">
                                    <Border.Effect>
                                        <DropShadowEffect Color="{DynamicResource ShadowColor}"
                                                          BlurRadius="12" ShadowDepth="3" Opacity="0.5"/>
                                    </Border.Effect>
                                </Border>
                                <ScrollViewer Margin="4,6" SnapsToDevicePixels="True">
                                    <StackPanel IsItemsHost="True"
                                                KeyboardNavigation.DirectionalNavigation="Contained"/>
                                </ScrollViewer>
                            </Grid>
                        </Popup>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- RadioButton / CheckBox -->
    <Style TargetType="RadioButton">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="FontSize" Value="12"/>
    </Style>
    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="FontSize" Value="12"/>
    </Style>

</ResourceDictionary>