<Window x:Class="GameLauncherPro.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        xmlns:ctrls="clr-namespace:GameLauncherPro.Controls"
        Title="GameLauncherPro · 典藏版"
        Height="900" Width="1400"
        WindowState="Maximized"
        Background="{DynamicResource MainBgBrush}">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ══════════════════ 内容滚动区 ══════════════════ -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                      Background="{DynamicResource MainBgBrush}">
            <StackPanel Margin="12,8">

                <!-- ─── 游戏库 ─── -->
                <Border Style="{StaticResource GameCard}" Margin="0,0,0,10" Padding="16,14">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- 标题行 -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10" HorizontalAlignment="Center">
                            <TextBlock Text="游戏库" FontSize="16" Foreground="{StaticResource GoldBrush}"
                                       FontWeight="Bold" VerticalAlignment="Center">
                                <TextBlock.Effect>
                                    <DropShadowEffect Color="#35D4A574" BlurRadius="5" ShadowDepth="0" Opacity="0.5"/>
                                </TextBlock.Effect>
                            </TextBlock>
                            <TextBlock x:Name="Tb_GameCount" Text="" FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </StackPanel>

                        <!-- 搜索 / 排序 / 刷新模式 -->
                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBox x:Name="Tb_Search" Width="220" Margin="0,0,10,0"
                                     VerticalAlignment="Center" TextChanged="Tb_Search_TextChanged"/>
                            <ComboBox x:Name="Cb_Filter" Width="200" Margin="0,0,10,0"
                                      VerticalAlignment="Center" SelectionChanged="Cb_Filter_SelectionChanged">
                                <ComboBoxItem Content="默认"/>
                                <ComboBoxItem Content="按游玩时间（从大到小）"/>
                                <ComboBoxItem Content="按最近打开（从近到远）"/>
                                <ComboBoxItem Content="按评分（从高到低）"/>
                            </ComboBox>

                            <TextBlock Text="图表刷新:" Foreground="{StaticResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" Margin="12,0,6,0" FontSize="12"/>
                            <RadioButton x:Name="Rb_Manual" Content="手动" GroupName="AutoRefreshMode"
                                         Margin="4,0" Checked="Rb_AutoManual_Checked"/>
                            <RadioButton x:Name="Rb_AutoOnAC" Content="插电" GroupName="AutoRefreshMode"
                                         Margin="4,0" Checked="Rb_AutoOnAC_Checked"/>
                            <RadioButton x:Name="Rb_Always" Content="始终" GroupName="AutoRefreshMode"
                                         Margin="4,0" Checked="Rb_AutoAlways_Checked"/>
                            <CheckBox x:Name="Cb_StrongPower" Content="强省电"
                                      Foreground="{StaticResource TextSecondaryBrush}"
                                      Margin="14,0,0,0" FontSize="12"
                                      Checked="Cb_StrongPower_Checked" Unchecked="Cb_StrongPower_Checked"/>
                        </StackPanel>

                        <!-- 卡片网格 -->
                        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled" Height="520">
                            <ItemsControl x:Name="GamePanel" HorizontalAlignment="Stretch"
                                          ItemsSource="{Binding Games}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <ctrls:VirtualizingWrapPanel ItemWidth="252" ItemHeight="398"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="240" Height="386" Margin="6"
                                                Style="{StaticResource GameCardHover}">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="*"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <Grid Width="216" Height="280" HorizontalAlignment="Center"
                                                      Margin="0,6,0,0">
                                                    <Rectangle Width="196" Height="240"
                                                               Fill="{StaticResource PlaceholderBrush}"
                                                               RadiusX="6" RadiusY="6"/>
                                                    <Image Width="216" Height="280" Stretch="UniformToFill"
                                                           Source="{Binding FrontImage}"
                                                           Visibility="{Binding IsFrontVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                    <Image Width="216" Height="280" Stretch="UniformToFill"
                                                           Source="{Binding BackImage}"
                                                           Visibility="{Binding IsBackVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                </Grid>
                                                <StackPanel Grid.Row="1" Orientation="Vertical"
                                                            HorizontalAlignment="Center" Margin="0,4,0,6">
                                                    <Button Content="{Binding Name}"
                                                            Background="Transparent" BorderThickness="0"
                                                            Foreground="{StaticResource TextPrimaryBrush}"
                                                            FontWeight="SemiBold" FontSize="13"
                                                            Margin="0,2,0,2" Padding="0" Cursor="Hand"
                                                            Click="CardName_Click"
                                                            ToolTip="点击启动游戏"/>
                                                    <TextBlock Text="{Binding StarsDisplay}"
                                                               Foreground="{StaticResource GoldBrush}"
                                                               FontSize="13" Margin="0,1,0,1"
                                                               TextAlignment="Center"
                                                               ToolTip="{Binding Score, StringFormat=评分：{0}/10}"/>
                                                    <TextBlock Text="{Binding DisplayPlayTime}"
                                                               Foreground="{StaticResource TextSecondaryBrush}"
                                                               FontSize="10" Margin="0,1,0,4"
                                                               TextAlignment="Center"/>
                                                    <StackPanel Orientation="Horizontal"
                                                                HorizontalAlignment="Center">
                                                        <Button Content="↻" Width="30" Height="26"
                                                                Style="{StaticResource GoldButton}"
                                                                FontSize="13" Padding="0"
                                                                ToolTip="翻转卡片" Click="CardFlip_Click"/>
                                                        <Button Content="★" Width="30" Height="26"
                                                                Style="{StaticResource GoldButton}"
                                                                FontSize="13" Padding="0" Margin="3,0"
                                                                ToolTip="设置评分" Click="CardSetScore_Click"/>
                                                        <Button Content="◧" Width="30" Height="26"
                                                                Style="{StaticResource GoldButton}"
                                                                FontSize="13" Padding="0"
                                                                ToolTip="设置正面封面" Click="CardSetFront_Click"/>
                                                        <Button Content="◨" Width="30" Height="26"
                                                                Style="{StaticResource GoldButton}"
                                                                FontSize="13" Padding="0" Margin="3,0"
                                                                ToolTip="设置反面封面" Click="CardSetBack_Click"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- ─── 实时运行 + 历史记录 ─── -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 实时运行 -->
                    <Border Style="{StaticResource GameCard}" Grid.Column="0" Padding="14,12">
                        <DockPanel>
                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Margin="0,0,0,8"
                                        HorizontalAlignment="Center">
                                <Ellipse x:Name="RunningIndicator" Width="8" Height="8"
                                         Fill="#3FB950" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="实时运行" FontSize="14"
                                           Foreground="{StaticResource GoldBrush}" FontWeight="Bold">
                                    <TextBlock.Effect>
                                        <DropShadowEffect Color="#35D4A574" BlurRadius="5" ShadowDepth="0" Opacity="0.5"/>
                                    </TextBlock.Effect>
                                </TextBlock>
                            </StackPanel>
                            <Button x:Name="Btn_AddGame" Content="＋ 加入库"
                                    Style="{StaticResource AccentButton}"
                                    Click="Btn_AddGame_Click" Margin="0,0,0,6" DockPanel.Dock="Top"
                                    HorizontalAlignment="Left"/>
                            <ScrollViewer Height="160">
                                <TextBox x:Name="Tb_Running"
                                         Background="{StaticResource PlaceholderBrush}"
                                         Foreground="{StaticResource TextPrimaryBrush}"
                                         IsReadOnly="True" FontSize="12" FontFamily="Consolas"
                                         BorderThickness="0"/>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>

                    <!-- 历史记录 -->
                    <Border Style="{StaticResource GameCard}" Grid.Column="2" Padding="14,12">
                        <DockPanel>
                            <Border DockPanel.Dock="Top" Margin="0,0,0,8">
                                <TextBlock Text="历史记录" FontSize="14"
                                           Foreground="{StaticResource GoldBrush}" FontWeight="Bold"
                                           HorizontalAlignment="Center">
                                    <TextBlock.Effect>
                                        <DropShadowEffect Color="#35D4A574" BlurRadius="5" ShadowDepth="0" Opacity="0.5"/>
                                    </TextBlock.Effect>
                                </TextBlock>
                            </Border>
                            <ScrollViewer Height="200">
                                <TextBox x:Name="Tb_Record"
                                         Background="{StaticResource PlaceholderBrush}"
                                         Foreground="{StaticResource TextPrimaryBrush}"
                                         IsReadOnly="True" FontSize="12" FontFamily="Consolas"
                                         BorderThickness="0"/>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>
                </Grid>

                <!-- ─── 图表 ─── -->
                <Border Style="{StaticResource GameCard}" Margin="0,0,0,10" Padding="16,14" Height="340">
                    <DockPanel>
                        <Border DockPanel.Dock="Top" Margin="0,0,0,8">
                            <TextBlock Text="游戏时长统计" FontSize="14"
                                       Foreground="{StaticResource GoldBrush}" FontWeight="Bold"
                                       HorizontalAlignment="Center">
                                <TextBlock.Effect>
                                    <DropShadowEffect Color="#35D4A574" BlurRadius="5" ShadowDepth="0" Opacity="0.5"/>
                                </TextBlock.Effect>
                            </TextBlock>
                        </Border>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="240"/>
                            </Grid.ColumnDefinitions>
                            <lvc:CartesianChart x:Name="Lc_BarChart" Grid.Column="0" Margin="6"
                                                Background="{StaticResource ChartBgBrush}"/>
                            <lvc:PieChart x:Name="Lc_PieChart" Grid.Column="1" Margin="6"
                                          Background="{StaticResource ChartBgBrush}"/>
                            <ScrollViewer Grid.Column="2" Margin="6,0">
                                <TextBlock x:Name="Tb_Rank"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="12" FontFamily="Consolas"
                                           Padding="10,4"/>
                            </ScrollViewer>
                        </Grid>
                    </DockPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- ══════════════════ 顶部标题栏 ══════════════════ -->
        <Border Grid.Row="0" Style="{StaticResource HeaderPanel}">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                    <Button x:Name="Btn_ChangeFolder" Content="切换游戏文件夹"
                            Style="{StaticResource GoldButton}"
                            Click="Btn_ChangeFolder_Click"/>
                    <Button x:Name="Btn_Refresh" Content="刷新数据"
                            Style="{StaticResource GoldButton}" Margin="6,0,0,0"
                            Click="Btn_Refresh_Click"/>
                </StackPanel>
                <Grid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="GameLauncherPro" FontSize="28"
                                   Foreground="{StaticResource GoldBrush}" FontWeight="SemiBold"
                                   FontFamily="Segoe UI" VerticalAlignment="Center">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="#40D4A574" BlurRadius="8" ShadowDepth="0" Opacity="0.5"/>
                            </TextBlock.Effect>
                        </TextBlock>
                        <TextBlock Text="典藏版" FontSize="13"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" Margin="10,4,0,0"/>
                    </StackPanel>
                </Grid>
            </DockPanel>
        </Border>

        <!-- ══════════════════ 底部状态栏 ══════════════════ -->
        <Border Grid.Row="2" Background="{StaticResource PanelBgBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="16,4">
            <DockPanel>
                <TextBlock x:Name="Tb_StatusDir" FontSize="11"
                           Foreground="{StaticResource TextMutedBrush}"
                           DockPanel.Dock="Left" VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" MaxWidth="600"/>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                    <TextBlock x:Name="Tb_StatusTotal" FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="0,0,20,0"/>
                    <TextBlock x:Name="Tb_StatusNum" FontSize="11"
                               Foreground="{StaticResource TextMutedBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </DockPanel>
        </Border>

    </Grid>
</Window>
