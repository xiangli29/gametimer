<Window x:Class="GameLauncherPro.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrls="clr-namespace:GameLauncherPro.Controls"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        Title="GameLauncherPro"
        Width="1400"
        Height="900"
        MinWidth="1120"
        MinHeight="720"
        WindowState="Maximized"
        Background="#0B0A09">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="32" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="208" />
            <ColumnDefinition Width="1" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.Column="0" Background="{StaticResource SidebarBrush}">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top" Margin="20,24,20,18">
                    <TextBlock Text="GameLauncherPro"
                               FontSize="16"
                               FontWeight="SemiBold"
                               TextWrapping="NoWrap"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBlock Text="游戏收藏与时长管理"
                               Margin="0,5,0,0"
                               Style="{StaticResource FieldLabel}" />
                </StackPanel>

                <StackPanel DockPanel.Dock="Top">
                    <Button x:Name="Btn_NavLibrary"
                            Style="{StaticResource NavButton}"
                            Click="NavLibrary_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8F1;" FontFamily="{StaticResource IconFont}" FontSize="15" Width="25" />
                            <TextBlock Text="游戏库" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="Btn_NavOverview"
                            Style="{StaticResource NavButton}"
                            Click="NavOverview_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE9D9;" FontFamily="{StaticResource IconFont}" FontSize="15" Width="25" />
                            <TextBlock Text="数据概览" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="Btn_NavMonitor"
                            Style="{StaticResource NavButton}"
                            Click="NavMonitor_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE7F4;" FontFamily="{StaticResource IconFont}" FontSize="15" Width="25" />
                            <TextBlock Text="监控与设置" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <Border DockPanel.Dock="Bottom"
                        Margin="12,0,12,18"
                        Padding="12"
                        Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="RunningIndicator" Width="8" Height="8" Margin="0,0,7,0" Fill="#66737D" />
                            <TextBlock Text="进程监控" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
                        </StackPanel>
                        <TextBlock Text="后台运行中"
                                   Margin="15,5,0,0"
                                   Style="{StaticResource FieldLabel}" />
                    </StackPanel>
                </Border>
            </DockPanel>
        </Border>

        <Border Grid.Row="0" Grid.Column="1" Background="{StaticResource BorderBrush}" />

        <Grid Grid.Row="0" Grid.Column="2">
            <Grid x:Name="LibraryPage" Margin="20,18,20,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="游戏库"
                                       FontSize="24"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock x:Name="Tb_GameCount"
                                       Margin="10,8,0,0"
                                       Style="{StaticResource FieldLabel}" />
                        </StackPanel>
                        <TextBlock Text="封面、时长与启动项"
                                   Margin="0,5,0,0"
                                   Style="{StaticResource FieldLabel}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="Btn_FlipAll"
                            Style="{StaticResource SecondaryButton}"
                            Content="翻转所有封面"
                            Margin="0,0,8,0"
                            Click="Btn_FlipAll_Click" />
                    <Button x:Name="Btn_Refresh"
                            Style="{StaticResource SecondaryButton}"
                            Content="刷新数据"
                            VerticalAlignment="Center"
                            Click="Btn_Refresh_Click" />
                    </StackPanel>
                </Grid>

                <Border Grid.Row="1"
                        Margin="0,20,0,16"
                        Padding="12"
                        Style="{StaticResource SectionPanel}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="搜索"
                                   Margin="0,0,8,0"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource FieldLabel}" />
                        <TextBox x:Name="Tb_Search"
                                 Width="300"
                                 TextChanged="Tb_Search_TextChanged" />
                        <TextBlock Text="排序"
                                   Margin="18,0,8,0"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource FieldLabel}" />
                        <ComboBox x:Name="Cb_Filter"
                                  Width="210"
                                  SelectedIndex="2"
                                  SelectionChanged="Cb_Filter_SelectionChanged">
                            <ComboBoxItem Content="默认" />
                            <ComboBoxItem Content="按游玩时间（从大到小）" />
                            <ComboBoxItem Content="按最近打开（从近到远）" />
                            <ComboBoxItem Content="按评分（从高到低）" />
                        </ComboBox>
                    </StackPanel>
                </Border>

                <ListBox x:Name="GamePanel"
                         Grid.Row="2"
                         ItemsSource="{Binding GamesView}">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ctrls:VirtualizingWrapPanel ItemWidth="289"
                                                         ItemHeight="466" />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Width="273"
                                    Height="450"
                                    Margin="8"
                                    Style="{StaticResource GameCard}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="326" />
                                        <RowDefinition Height="70" />
                                        <RowDefinition Height="34" />
                                    </Grid.RowDefinitions>

                                    <Button Width="253"
                                            Height="326"
                                            Style="{StaticResource CardCoverButton}"
                                            ToolTip="点击翻转正反封面"
                                            Click="CardFlip_Click">
                                    <Grid Width="253" Height="326" ClipToBounds="True">
                                        <Rectangle Fill="{StaticResource PlaceholderBrush}" />
                                        <TextBlock Text="{Binding Name}"
                                                   Margin="18"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Center"
                                                   TextAlignment="Center"
                                                   TextWrapping="Wrap"
                                                   Foreground="{StaticResource TextMutedBrush}" />
                                        <Image Width="253"
                                               Height="326"
                                               Stretch="UniformToFill"
                                               Source="{Binding FrontImage}"
                                               Visibility="{Binding IsFrontVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
                                        <Image Width="253"
                                               Height="326"
                                               Stretch="UniformToFill"
                                               Source="{Binding BackImage}"
                                               Visibility="{Binding IsBackVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    </Grid>
                                    </Button>

                                    <StackPanel Grid.Row="1" Margin="0,10,0,6">
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding Name}" />
                                        <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                            <TextBlock Text="{Binding Score, StringFormat=评分 {0}/10}"
                                                       FontSize="11"
                                                       Foreground="{StaticResource AccentBrush}"
                                                       ToolTip="{Binding Score, StringFormat=评分：{0}/10}" />
                                            <TextBlock Text="{Binding DisplayPlayTime}"
                                                       Margin="8,0,0,0"
                                                       FontSize="11"
                                                       Foreground="{StaticResource TextSecondaryBrush}" />
                                        </StackPanel>
                                        <TextBlock Text="{Binding LastPlay}"
                                                   Margin="0,4,0,0"
                                                   FontSize="10"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding LastPlay}" />
                                    </StackPanel>

                                    <Grid Grid.Row="2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="34" />
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0"
                                                Style="{StaticResource PrimaryButton}"
                                                Content="启动游戏"
                                                Padding="10,6"
                                                Click="CardName_Click" />
                                        <Button Grid.Column="2"
                                                Style="{StaticResource IconButton}"
                                                Content="&#xE712;"
                                                ToolTip="管理游戏"
                                                Click="CardMore_Click" />
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>

            <ScrollViewer x:Name="OverviewPage"
                          Margin="20,18,20,16"
                          Visibility="Collapsed"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="数据概览"
                               FontSize="24"
                               FontWeight="SemiBold" />
                    <TextBlock Text="游玩时间与收藏构成"
                               Margin="0,5,0,20"
                               Style="{StaticResource FieldLabel}" />

                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Style="{StaticResource MetricCard}">
                            <StackPanel>
                                <TextBlock Text="游戏总数" Style="{StaticResource FieldLabel}" />
                                <TextBlock x:Name="Tb_OverviewGameCount"
                                           Margin="0,6,0,0"
                                           FontSize="26"
                                           FontWeight="SemiBold" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2" Style="{StaticResource MetricCard}">
                            <StackPanel>
                                <TextBlock Text="累计时长" Style="{StaticResource FieldLabel}" />
                                <TextBlock x:Name="Tb_OverviewTotalTime"
                                           Margin="0,6,0,0"
                                           FontSize="26"
                                           FontWeight="SemiBold" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="4" Style="{StaticResource MetricCard}">
                            <StackPanel>
                                <TextBlock Text="最近游玩" Style="{StaticResource FieldLabel}" />
                                <TextBlock x:Name="Tb_OverviewRecentGame"
                                           Margin="0,8,0,0"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Padding="16" Margin="0,0,0,16" Style="{StaticResource SectionPanel}">
                        <StackPanel>
                            <TextBlock Text="游玩时长"
                                       FontSize="15"
                                       FontWeight="SemiBold" />
                            <lvc:CartesianChart x:Name="Lc_BarChart"
                                                Height="300"
                                                Margin="0,12,0,0"
                                                Background="{StaticResource ChartBgBrush}" />
                        </StackPanel>
                    </Border>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="320" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Padding="16" Style="{StaticResource SectionPanel}">
                            <StackPanel>
                                <TextBlock Text="时长分布"
                                           FontSize="15"
                                           FontWeight="SemiBold" />
                                <lvc:PieChart x:Name="Lc_PieChart"
                                              Height="300"
                                              Margin="0,12,0,0"
                                              Background="{StaticResource ChartBgBrush}" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2" Padding="16" Style="{StaticResource SectionPanel}">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top"
                                           Text="排行榜"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,12" />
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <TextBlock x:Name="Tb_Rank"
                                               FontFamily="Consolas"
                                               FontSize="12"
                                               Foreground="{StaticResource TextSecondaryBrush}" />
                                </ScrollViewer>
                            </DockPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer x:Name="MonitorPage"
                          Margin="20,18,20,16"
                          Visibility="Collapsed"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="监控与设置"
                               FontSize="24"
                               FontWeight="SemiBold" />
                    <TextBlock Text="运行状态、目录与图表刷新策略"
                               Margin="0,5,0,20"
                               Style="{StaticResource FieldLabel}" />

                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Padding="16" Style="{StaticResource SectionPanel}">
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Top"
                                            Orientation="Horizontal"
                                            Margin="0,0,0,12">
                                    <TextBlock Text="当前运行游戏"
                                               FontSize="15"
                                               FontWeight="SemiBold" />
                                    <Button x:Name="Btn_AddGame"
                                            Margin="12,0,0,0"
                                            Style="{StaticResource PrimaryButton}"
                                            Content="加入当前游戏"
                                            Click="Btn_AddGame_Click" />
                                </StackPanel>
                                <TextBox x:Name="Tb_Running"
                                         Height="180"
                                         IsReadOnly="True"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         FontFamily="Consolas"
                                         Foreground="{StaticResource TextSecondaryBrush}" />
                            </DockPanel>
                        </Border>
                        <Border Grid.Column="2" Padding="16" Style="{StaticResource SectionPanel}">
                            <StackPanel>
                                <TextBlock Text="监控目录"
                                           FontSize="15"
                                           FontWeight="SemiBold" />
                                <TextBlock x:Name="Tb_MonitorDirectory"
                                           Margin="0,12,0,12"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}" />
                                <Button x:Name="Btn_ChangeFolder"
                                        Width="132"
                                        HorizontalAlignment="Left"
                                        Style="{StaticResource SecondaryButton}"
                                        Content="切换文件夹"
                                        Click="Btn_ChangeFolder_Click" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Padding="16" Margin="0,0,0,16" Style="{StaticResource SectionPanel}">
                        <StackPanel>
                            <TextBlock Text="图表刷新"
                                       FontSize="15"
                                       FontWeight="SemiBold" />
                            <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                                <RadioButton x:Name="Rb_Manual"
                                             Content="手动"
                                             GroupName="AutoRefreshMode"
                                             Margin="0,0,18,0"
                                             Checked="Rb_AutoManual_Checked" />
                                <RadioButton x:Name="Rb_AutoOnAC"
                                             Content="插电时"
                                             GroupName="AutoRefreshMode"
                                             Margin="0,0,18,0"
                                             Checked="Rb_AutoOnAC_Checked" />
                                <RadioButton x:Name="Rb_Always"
                                             Content="始终"
                                             GroupName="AutoRefreshMode"
                                             Margin="0,0,24,0"
                                             Checked="Rb_AutoAlways_Checked" />
                                <CheckBox x:Name="Cb_StrongPower"
                                          Content="强省电"
                                          Checked="Cb_StrongPower_Checked"
                                          Unchecked="Cb_StrongPower_Checked" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Padding="16" Margin="0,0,0,16" Style="{StaticResource SectionPanel}">
                        <StackPanel>
                            <TextBlock Text="记录备份"
                                       FontSize="15"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="导入会替换当前游戏记录"
                                       Margin="0,5,0,12"
                                       Style="{StaticResource FieldLabel}" />
                            <StackPanel Orientation="Horizontal">
                                <Button Style="{StaticResource SecondaryButton}"
                                        Content="导出 JSON"
                                        Margin="0,0,8,0"
                                        Click="Btn_ExportJson_Click" />
                                <Button Style="{StaticResource SecondaryButton}"
                                        Content="导入 JSON"
                                        Click="Btn_ImportJson_Click" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Padding="16" Style="{StaticResource SectionPanel}">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top"
                                       Text="游戏记录"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,12" />
                            <TextBox x:Name="Tb_Record"
                                     Height="260"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     FontFamily="Consolas"
                                     FontSize="12"
                                     Foreground="{StaticResource TextSecondaryBrush}" />
                        </DockPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Border x:Name="DrawerBackdrop"
                    Background="#88000000"
                    Panel.ZIndex="9"
                    Visibility="{Binding HasSelectedGame, Converter={StaticResource BoolToVisibilityConverter}}"
                    MouseLeftButtonDown="DrawerBackdrop_MouseLeftButtonDown" />

            <Border x:Name="DrawerHost"
                    Width="420"
                    HorizontalAlignment="Right"
                    Background="{StaticResource SidebarBrush}"
                    BorderBrush="{StaticResource BorderStrongBrush}"
                    BorderThickness="1,0,0,0"
                    Panel.ZIndex="10"
                    Visibility="{Binding HasSelectedGame, Converter={StaticResource BoolToVisibilityConverter}}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20" DataContext="{Binding SelectedGame}">
                        <Grid Margin="0,0,0,20">
                            <TextBlock Text="游戏详情"
                                       FontSize="20"
                                       FontWeight="SemiBold" />
                            <Button x:Name="Btn_CloseDrawer"
                                    HorizontalAlignment="Right"
                                    Style="{StaticResource IconButton}"
                                    Content="&#xE711;"
                                    ToolTip="关闭详情"
                                    Click="Btn_CloseDrawer_Click" />
                        </Grid>

                        <Grid Width="253"
                              Height="326"
                              HorizontalAlignment="Center"
                              ClipToBounds="True">
                            <Rectangle Fill="{StaticResource PlaceholderBrush}" />
                            <Image Width="253"
                                   Height="326"
                                   Stretch="UniformToFill"
                                   Source="{Binding FrontImage}"
                                   Visibility="{Binding IsFrontVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
                            <Image Width="253"
                                   Height="326"
                                   Stretch="UniformToFill"
                                   Source="{Binding BackImage}"
                                   Visibility="{Binding IsBackVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
                        </Grid>

                        <TextBlock Text="{Binding Name}"
                                   Margin="0,16,0,0"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding Name}" />

                        <TextBlock Text="游戏名称"
                                   Margin="0,18,0,6"
                                   Style="{StaticResource FieldLabel}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="74" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="Tb_DrawerName" />
                            <Button Grid.Column="2"
                                    Style="{StaticResource SecondaryButton}"
                                    Content="保存名称"
                                    Padding="8,6"
                                    Click="Btn_SaveDrawerName_Click" />
                        </Grid>

                        <TextBlock Text="评分"
                                   Margin="0,18,0,6"
                                   Style="{StaticResource FieldLabel}" />
                        <StackPanel Orientation="Horizontal">
                            <Button Width="28" Height="28" Margin="0,0,8,0" Tag="1" Background="{Binding ScoreTile1Brush}" Style="{StaticResource ScoreTileButton}" ToolTip="1" Click="ScoreOption_Click" />
                            <Button Width="28" Height="28" Margin="0,0,8,0" Tag="2" Background="{Binding ScoreTile2Brush}" Style="{StaticResource ScoreTileButton}" ToolTip="2" Click="ScoreOption_Click" />
                            <Button Width="28" Height="28" Margin="0,0,8,0" Tag="3" Background="{Binding ScoreTile3Brush}" Style="{StaticResource ScoreTileButton}" ToolTip="3" Click="ScoreOption_Click" />
                            <Button Width="28" Height="28" Margin="0,0,8,0" Tag="4" Background="{Binding ScoreTile4Brush}" Style="{StaticResource ScoreTileButton}" ToolTip="4" Click="ScoreOption_Click" />
                            <Button Width="28" Height="28" Margin="0,0,8,0" Tag="5" Background="{Binding ScoreTile5Brush}" Style="{StaticResource ScoreTileButton}" ToolTip="5" Click="ScoreOption_Click" />
                            <Button Width="28" Height="28" Margin="0,0,8,0" Tag="6" Background="{Binding ScoreTile6Brush}" Style="{StaticResource ScoreTileButton}" ToolTip="6" Click="ScoreOption_Click" />
                            <Button Width="28" Height="28" Margin="0,0,8,0" Tag="7" Background="{Binding ScoreTile7Brush}" Style="{StaticResource ScoreTileButton}" ToolTip="7" Click="ScoreOption_Click" />
                            <Button Width="28" Height="28" Margin="0,0,8,0" Tag="8" Background="{Binding ScoreTile8Brush}" Style="{StaticResource ScoreTileButton}" ToolTip="8" Click="ScoreOption_Click" />
                            <Button Width="28" Height="28" Margin="0,0,8,0" Tag="9" Background="{Binding ScoreTile9Brush}" Style="{StaticResource ScoreTileButton}" ToolTip="9" Click="ScoreOption_Click" />
                            <Button Width="28" Height="28" Tag="10" Background="{Binding ScoreTile10Brush}" Style="{StaticResource ScoreTileButton}" ToolTip="10" Click="ScoreOption_Click" />
                        </StackPanel>
                        <TextBlock Text="{Binding Score, StringFormat=当前评分：{0}/10}"
                                   FontSize="13"
                                   Foreground="{StaticResource AccentBrush}" />

                        <TextBlock Text="累计时长"
                                   Margin="0,18,0,6"
                                   Style="{StaticResource FieldLabel}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="74" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="Tb_DrawerHours" ToolTip="小时" />
                            <TextBox x:Name="Tb_DrawerMinutes" Grid.Column="2" ToolTip="分钟" />
                            <Button Grid.Column="4"
                                    Style="{StaticResource SecondaryButton}"
                                    Content="保存时长"
                                    Padding="8,6"
                                    Click="Btn_SaveDrawerTime_Click" />
                        </Grid>

                        <TextBlock Text="封面与显示面"
                                   Margin="0,18,0,6"
                                   Style="{StaticResource FieldLabel}" />
                        <WrapPanel>
                            <Button Style="{StaticResource SecondaryButton}"
                                    Content="设置正面"
                                    Margin="0,0,8,8"
                                    Click="CardSetFront_Click" />
                            <Button Style="{StaticResource SecondaryButton}"
                                    Content="设置背面"
                                    Margin="0,0,8,8"
                                    Click="CardSetBack_Click" />
                            <Button Style="{StaticResource SecondaryButton}"
                                    Content="切换显示面"
                                    Margin="0,0,0,8"
                                    Click="CardFlip_Click" />
                        </WrapPanel>

                        <Grid Margin="0,12,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="精彩截图"
                                       FontSize="15"
                                       FontWeight="SemiBold" />
                            <Button Grid.Column="1"
                                    Style="{StaticResource SecondaryButton}"
                                    Content="添加截图"
                                    Padding="10,6"
                                    Click="Btn_AddScreenshots_Click" />
                        </Grid>
                        <Grid Width="253"
                              Height="326"
                              HorizontalAlignment="Center"
                              ClipToBounds="True">
                            <Rectangle Fill="{StaticResource PlaceholderBrush}" />
                            <Image Source="{Binding DataContext.CurrentScreenshot.Image, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                   Stretch="UniformToFill" />
                        </Grid>
                        <Grid Width="253" Margin="0,10,0,0" HorizontalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="34" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="34" />
                            </Grid.ColumnDefinitions>
                            <Button Style="{StaticResource IconButton}"
                                    Content="&#xE76B;"
                                    ToolTip="上一张截图"
                                    IsEnabled="{Binding DataContext.CanShowPreviousScreenshot, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                    Click="Btn_PreviousScreenshot_Click" />
                            <TextBlock Grid.Column="1"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Text="{Binding DataContext.ScreenshotPositionText, RelativeSource={RelativeSource AncestorType={x:Type Window}}}" />
                            <Button Grid.Column="2"
                                    Style="{StaticResource IconButton}"
                                    Content="&#xE76C;"
                                    ToolTip="下一张截图"
                                    IsEnabled="{Binding DataContext.CanShowNextScreenshot, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                    Click="Btn_NextScreenshot_Click" />
                        </Grid>
                        <Button Style="{StaticResource SecondaryButton}"
                                Content="删除当前截图"
                                HorizontalAlignment="Center"
                                Margin="0,8,0,0"
                                IsEnabled="{Binding DataContext.HasScreenshots, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                Click="Btn_DeleteCurrentScreenshot_Click" />

                        <TextBlock Text="启动程序"
                                   Margin="0,10,0,6"
                                   Style="{StaticResource FieldLabel}" />
                        <TextBlock Text="{Binding LaunchExeDisplay}"
                                   Margin="0,0,0,8"
                                   FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding LaunchExeDisplay}" />
                        <Button Style="{StaticResource SecondaryButton}"
                                Content="选择启动程序"
                                HorizontalAlignment="Left"
                                Click="CardSwitchExe_Click" />

                        <Separator Margin="0,20,0,16" Background="{StaticResource BorderBrush}" />
                        <Button Style="{StaticResource DangerButton}"
                                Content="删除此游戏"
                                HorizontalAlignment="Left"
                                Click="CardDelete_Click" />
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <Border Grid.Row="1"
                Grid.ColumnSpan="3"
                Background="{StaticResource SidebarBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <DockPanel Margin="16,0">
                <TextBlock x:Name="Tb_StatusDir"
                           MaxWidth="700"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource TextMutedBrush}"
                           TextTrimming="CharacterEllipsis" />
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <TextBlock x:Name="Tb_StatusTotal"
                               Margin="0,0,24,0"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}" />
                    <TextBlock x:Name="Tb_StatusNum"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextMutedBrush}" />
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
